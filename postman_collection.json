{
  "info": {
    "name": "OCFL Procurement Portal Demo",
    "_postman_id": "91db27df-6d47-4d52-a2b6-7fd4837f2610",
    "description": "Postman collection for the local OCFL procurement portal demo API.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5002" },
    { "key": "submissionId", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] }
      }
    },
    {
      "name": "Upload Quote",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "file", "type": "file", "src": "sample_quote.pdf" },
            { "key": "department", "type": "text", "value": "Public Works" },
            { "key": "requestor_name", "type": "text", "value": "John D. Example" },
            { "key": "requestor_phone", "type": "text", "value": "407-836-1018" },
            { "key": "requisition_number", "type": "text", "value": "REQ-2026-009" }
          ]
        },
        "url": { "raw": "{{baseUrl}}/api/upload", "host": ["{{baseUrl}}"], "path": ["api", "upload"] }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 201', function () { pm.response.to.have.status(201); });",
              "var json = pm.response.json();",
              "if (json.submission_id) { pm.collectionVariables.set('submissionId', json.submission_id); }"
            ]
          }
        }
      ]
    },
    {
      "name": "Validate Submission",
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" } ],
        "body": { "mode": "raw", "raw": "{\n  \"submission_id\": \"{{submissionId}}\"\n}" },
        "url": { "raw": "{{baseUrl}}/api/validate", "host": ["{{baseUrl}}"], "path": ["api", "validate"] }
      }
    },
    {
      "name": "Get Piggyback Prefill",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/forms/piggyback/prefill?submission_id={{submissionId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "forms", "piggyback", "prefill"],
          "query": [ { "key": "submission_id", "value": "{{submissionId}}" } ]
        }
      }
    },
    {
      "name": "Save Piggyback Checklist",
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" } ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"submission_id\": \"{{submissionId}}\",\n  \"fields\": {\n    \"Vendor Name\": \"ABC Supplies, Inc.\",\n    \"Requisition Number\": \"REQ-2026-009\",\n    \"Date Submitted\": \"03/14/2026\",\n    \"Department/Division\": \"Public Works\",\n    \"Requestor Name\": \"John D. Example\",\n    \"Requestor Phone\": \"407-836-1018\",\n    \"Contract Number\": \"ACS-2024-001\",\n    \"Confirm Contract is on the ACS log\": true,\n    \"Contract is not expired\": true,\n    \"Vendor name on contract matches quote\": true,\n    \"Line-by-line pricing validation\": true\n  }\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/forms/piggyback/save", "host": ["{{baseUrl}}"], "path": ["api", "forms", "piggyback", "save"] }
      }
    },
    {
      "name": "Upload COI",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "submission_id", "type": "text", "value": "{{submissionId}}" },
            { "key": "file", "type": "file", "src": "sample_coi.pdf" }
          ]
        },
        "url": { "raw": "{{baseUrl}}/api/attachments/coi", "host": ["{{baseUrl}}"], "path": ["api", "attachments", "coi"] }
      }
    },
    {
      "name": "Download Piggyback PDF",
      "request": {
        "method": "GET",
        "header": [],
        "url": { "raw": "{{baseUrl}}/api/download/piggyback/{{submissionId}}", "host": ["{{baseUrl}}"], "path": ["api", "download", "piggyback", "{{submissionId}}"] }
      }
    },
    {
      "name": "List Rules",
      "request": {
        "method": "GET",
        "header": [],
        "url": { "raw": "{{baseUrl}}/api/admin/rules", "host": ["{{baseUrl}}"], "path": ["api", "admin", "rules"] }
      }
    }
  ]
}
